       "       [-1,  2,  1]])"
      ]
     },
     "execution_count": 10,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "A = np.array([\n",
    "    [1, 2 , 1],\n",
    "    [2, 1, 1], \n",
    "    [-1, 2 ,1]\n",
    "])\n",
    "\n",
    "A"
   ]
  },
